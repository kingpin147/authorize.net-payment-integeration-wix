import { fetch } from 'wix-fetch';
import { getSecret } from 'wix-secrets-backend';
import * as xml2js from 'xml2js';

export async function createTransaction(data) {
    
    const apiLoginId = (await getSecret("apiLoginId")).trim();
    const transactionKey = (await getSecret("transactionKey")).trim();
    const apiUrl = 'https://apitest.authorize.net/xml/v1/request.api';

    // const authHeader = btoa(apiLoginId + ':' + transactionKey);
    const authHeader = Buffer.from(apiLoginId + ':' + transactionKey).toString('base64');
    const headers = {
        'Content-Type': 'application/json',
        'Authorization': 'Basic ' + authHeader
    };

    // const amount = 19.99;
    // const creditCardNumber = '4111111111111111';
    // const expirationDate = '2024-04';
    // const cvv = '123';

    const payload = {
        createTransactionRequest: {
            merchantAuthentication: {
                name: apiLoginId,
                transactionKey: transactionKey
            },
            transactionRequest: {
                transactionType: 'authCaptureTransaction',
                amount: data.amount,
                payment: {
                    creditCard: {
                        cardNumber: data.cardNumber,
                        expirationDate: data.expirationDate,
                        cardCode: data.cardCode
                    }
                }
            }
        }
    };

    try {
        const response = await fetch(apiUrl, {
            method: 'POST',
            headers: headers,
            body: JSON.stringify(payload)
        });

        return await response.json();
    } catch (error) {
        console.error('Error:', error);
        return null;
    }
}

export async function processTransaction(data) {
    try {
        const response = await createTransaction(data);
        return response;
    } catch (error) {
        console.error('Error:', error);
        return null;
    }
}


