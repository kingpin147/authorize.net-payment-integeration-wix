	<name>${apiLoginId}</name>
	<transactionKey>${transactionKey}</transactionKey>
  </merchantAuthentication>
  <transactionRequest>
	<transactionType>authCaptureTransaction</transactionType>
	<amount>${data.amount}</amount>
	<payment>
	  <creditCard>
		<cardNumber>${data.cardNumber}</cardNumber>
		<expirationDate>${data.expirationDate}</expirationDate>
		<cardCode>${data.cardCode}</cardCode>
	  </creditCard>
	</payment>
	<order>
	  <invoiceNumber>INV-${data.cardNumber}</invoiceNumber>
	  <description>${data.firstName}</description>
	</order>
	<lineItems>
	  <lineItem>
		<itemId>${data.cardCode}</itemId>
		<name>Instagram</name>
		<description>Bought Instagram</description>
		<quantity>1</quantity>
		<unitPrice>${data.amount}</unitPrice>
	  </lineItem>
	</lineItems>
	<customer>
